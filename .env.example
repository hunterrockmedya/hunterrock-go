# Hunterrock GO - Örnek Yapılandırma
# ====================================
# Bu dosyayı manuel oluşturmak yerine kurulum sihirbazını kullanın:
#
#   npm run setup
#
# Sihirbaz her şeyi otomatik hazırlar.

# Ortam (development veya production)
NODE_ENV=production

# Sunucu Ayarları
PORT=3000

# Domain (Ziyaretçilerin erişeceği adres)
DOMAIN=https://go.example.com

# Session Güvenliği (setup.js otomatik 64-byte üretir)
SESSION_SECRET=OTOMATIK_URETILIR
